// Test file para verificar conflicto entre guarded y reentrant

contract TestConflict {
    state var balance: int = 0;

    constructor() {
        balance = 0;
    }

    // Test inválido: función con guarded y reentrant - debe fallar
    external function conflictingFunction() guarded reentrant {
        balance = balance + 1;
    }
}
